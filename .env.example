# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_garage

# Server Configuration
PORT=8000

# Session Security
SESSION_SECRET=your_very_secure_random_secret_min_32_chars

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:8000

# Camera Configuration (ESP32)
CAMERA_IP=192.168.0.226
CAMERA_PORT=81

# MQTT Broker
MQTT_BROKER=broker.emqx.io
MQTT_PORT=8084
MQTT_PATH=/mqtt

# AI Service URL
AI_API_URL=http://localhost:8000
